{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lead Enrichment Output",
  "type": "object",
  "required": ["company", "context", "lead_score", "icp_tier", "enrichment_notes"],
  "properties": {
    "first_name": { "type": "string" },
    "last_name": { "type": "string" },
    "company": { "type": "string" },
    "job_title": { "type": "string" },
    "email": { "type": "string", "format": "email" },
    "phone": { "type": "string" },
    "website": { "type": "string", "format": "uri" },
    "linkedin": { "type": "string", "format": "uri" },
    "industry": { "type": "string" },
    "company_size": { "type": "string" },
    "context": { "type": "string", "minLength": 10 },
    "lead_score": { "type": "number", "minimum": 0, "maximum": 10 },
    "lead_source": { "type": "string" },
    "business_brand": { "type": "string" },
    "enrichment_notes": { "type": "string" },
    "icp_tier": { "type": "string", "enum": ["hot", "warm", "cold"] },
    "export_markets": { "type": "array", "items": { "type": "string" } },
    "import_sources": { "type": "array", "items": { "type": "string" } },
    "trade_products": { "type": "array", "items": { "type": "string" } },
    "recent_news": { "type": "array", "items": { "type": "string" } },
    "tech_stack": { "type": "array", "items": { "type": "string" } },
    "decision_makers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "title": { "type": "string" },
          "linkedin": { "type": "string" }
        }
      }
    }
  }
}
