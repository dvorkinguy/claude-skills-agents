{
    "title": "Puppeteer Scraper Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "startUrls": {
            "sectionCaption": "Input",
            "title": "Start URLs",
            "type": "array",
            "description": "URLs to start scraping from",
            "editor": "requestListSources",
            "prefill": [
                {"url": "https://example.com"}
            ]
        },
        "maxItems": {
            "title": "Max Items",
            "type": "integer",
            "description": "Maximum number of items to scrape (0 = unlimited)",
            "default": 100,
            "minimum": 0
        },
        "proxyConfig": {
            "sectionCaption": "Proxy",
            "title": "Proxy Configuration",
            "type": "object",
            "description": "Proxy settings for the scraper",
            "editor": "proxy",
            "default": {
                "useApifyProxy": true
            }
        },
        "maxConcurrency": {
            "sectionCaption": "Advanced",
            "title": "Max Concurrency",
            "type": "integer",
            "description": "Maximum concurrent browser pages",
            "default": 5,
            "minimum": 1,
            "maximum": 20
        },
        "navigationTimeoutSecs": {
            "title": "Navigation Timeout (seconds)",
            "type": "integer",
            "description": "Maximum time to wait for page navigation",
            "default": 60,
            "minimum": 10,
            "maximum": 300
        },
        "headless": {
            "title": "Headless Mode",
            "type": "boolean",
            "description": "Run browser in headless mode",
            "default": true
        },
        "debugMode": {
            "title": "Debug Mode",
            "type": "boolean",
            "description": "Enable detailed logging",
            "default": false
        }
    },
    "required": ["startUrls"]
}
